# ─── Vaeloom Environment Configuration ───

# Application
NODE_ENV=development
LOG_LEVEL=debug

# API Gateway
API_PORT=4000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# Web Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_SERVICE_URL=http://ai-service:8000
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_PROVIDER=anthropic

# Database
DATABASE_URL=postgresql://vaeloom:vaeloom_dev@localhost:5432/vaeloom

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=604800
JWT_ALGORITHM=HS256
JWT_ISSUER=vaeloom

# Encryption
ENCRYPTION_KEY=change-me-in-production-32-chars-min
INTEGRATION_ENCRYPTION_KEY=change-me-integration-enc-key-32chars

# Observability / Tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=vaeloom
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=true

# Service Ports
MEMORY_STORE_PORT=3010
AUTH_SERVICE_PORT=3020
KNOWLEDGE_GRAPH_PORT=3030
EVENT_BUS_PORT=3040
SEARCH_SERVICE_PORT=3050
AGENT_ENGINE_PORT=3060
ANALYTICS_SERVICE_PORT=3070
AUDIT_SERVICE_PORT=3080
BILLING_SERVICE_PORT=3090
CONNECTOR_SERVICE_PORT=3100
DOCUMENT_INGESTION_PORT=3110
IAM_SERVICE_PORT=3120
INTEGRATION_SERVICE_PORT=3130
JOB_SCHEDULER_PORT=3140
NOTIFICATION_SERVICE_PORT=3150
PLUGIN_SERVICE_PORT=3160
RBAC_SERVICE_PORT=3170
RECOMMENDATION_SERVICE_PORT=3180

# Microservice Environment (shared across all services)
EVENT_BUS_URL=http://event-bus:3040
AI_SERVICE_URL=http://ai-service:8000
MEMORY_STORE_URL=http://memory-store:3010
AUTH_SERVICE_URL=http://auth-service:3020

# Stripe (billing-service)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-11-20.acacia

# SMTP (notification-service)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vaeloom.dev

# Slack (notification-service)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Plugins
PLUGIN_SANDBOX_TIMEOUT=30000

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_ACQUIRE_TIMEOUT=10000
DB_POOL_MAX_USES=500

# PostgreSQL Extensions
POSTGRES_EXTENSIONS=pgcrypto,vector
